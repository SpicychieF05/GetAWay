rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Interview rooms ──────────────────────────────────────────────
    // Anyone with the room ID can read room data (candidate onboarding)
    // Only authenticated recruiters can create rooms
    match /rooms/{roomId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if true;  // Candidate onboarding writes here (no auth)
      allow delete: if request.auth != null;

      // WebRTC signaling — must be open to both parties (no auth)
      match /rtc/{doc} {
        allow read, write: if true;
      }
      match /rtcCaller/{doc} {
        allow read, write: if true;
      }
      match /rtcCallee/{doc} {
        allow read, write: if true;
      }

      // Alerts & Trust logs
      match /alerts/{alertId} {
        allow read, write: if true;
      }
      match /trustLogs/{logId} {
        allow read, write: if true;
      }
      match /report/{doc} {
        allow read, write: if true;
      }
    }

    // ── OTP codes ────────────────────────────────────────────────────
    // Written by server (Admin SDK) — client only needs to trigger via API route
    match /otpCodes/{email} {
      allow read, write: if false;  // Server-only via Admin SDK
    }

    // ── Recruiters ───────────────────────────────────────────────────
    match /recruiters/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
